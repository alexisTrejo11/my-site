# Keep build context small and avoid leaking local junk into the image
node_modules
dist
.angular
.git
.github
.gitignore
.vscode
.idea
coverage
tmp
out-tsc
__screenshots__
# Exclude docs at repo root, but keep published learning notes in the image.
*.md
!public/notes/**/*.md
docker-compose*.yml
.dockerignore
npm-debug.log
yarn-error.log
.DS_Store
